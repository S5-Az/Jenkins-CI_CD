pipeline {
  agent {
    docker { image 'node:22-alpine'}
  }
  stages {
    stage('Install') {
      steps{
        sh 'npm install'
      }
      stage('Test'){
        steps{
          sh 'npm test'
      }
      stage('Run'){
        steps{
          sh 'npm start'
      }
      }
      }
    }
  }
}