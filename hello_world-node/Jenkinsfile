pipeline {
    agent none
    stages {
        stage('Install and Test') {
            agent {
                docker {image 'node:16-alpine'}
            }
            steps {
                dir('hello_world-node') {
                    echo 'Building application........'
                    sh 'npm install'

                    echo 'Testing the application.......'
                    sh 'npm start'
                }
            }
        }
        stage('Build') {
            agent {
                docker {image 'docker:dind'
                args '--privileged -v /var/run/docker.sock:/var/run/docker.sock'}

            }
            steps {
                sh 'docker run --privileged -d --name my-dind docker:dind'
                sh 'docker exec -it my-dind docker ps'
            }

        }
    }
}